{
  "name": "localocr",
  "private": true,
  "version": "0.1.0",
  "description": "Privacy-first browser-local OCR toolkit",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @localocr/web",
    "build": "npm run build -w @localocr/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e -w @localocr/web",
    "test:all": "npm run test && npm run build && node scripts/check-asset-size.mjs",
    "test:ci": "npm run test:all && npm run test:e2e",
    "check:assets": "node scripts/check-asset-size.mjs",
    "preview": "npm run preview -w @localocr/web"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
